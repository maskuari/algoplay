<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tab_materi"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ScrollView
        android:id="@+id/lessonScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="112dp"
        android:paddingBottom="30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="188dp"
                android:background="@drawable/bg_home_hero_clean"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:elevation="2dp"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="10dp"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingEnd="132dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="Materi 8"
                        android:textColor="@color/algoplay_green_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="1dp"
                        android:text="Cara Membuat Flowchart yang Rapi"
                        android:textColor="@color/algoplay_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="2dp"
                        android:text="Bantu Robot Algo membaca flowchart tanpa bingung."
                        android:textColor="@color/algoplay_subtext"
                        android:textSize="13sp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="134dp"
                    android:layout_height="134dp"
                    android:layout_gravity="end|center_vertical"
                    android:adjustViewBounds="true"
                    android:contentDescription="Robot Algo merapikan flowchart"
                    android:scaleType="fitCenter"
                    android:src="@drawable/belajar_materi" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Tujuan Materi" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Anak-anak memahami cara membuat flowchart yang rapi, mudah dibaca, dan tidak membingungkan." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Halo, teman-teman!" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Robot Algo datang lagi nih! Kemarin kita sudah belajar simbol-simbol flowchart. Sekarang kita belajar cara membuat flowchart yang rapi." />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Flowchart yang rapi lebih mudah dibaca. Kalau flowchart berantakan, Robot Algo bisa bingung: Aduh, panahnya ke mana-mana!" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Jadi, kalau membuat flowchart, kita harus membuatnya jelas dan rapi." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Penjelasan Fun" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Bayangkan flowchart itu seperti jalan untuk Robot Algo. Kalau jalannya lurus dan panahnya jelas, Algo bisa berjalan dengan mudah." />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Tapi kalau jalannya muter-muter, panahnya bertabrakan, dan tulisannya terlalu panjang, Algo bisa pusing." />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Flowchart yang rapi itu seperti jalan yang bersih: MULAI, langkah-langkah, lalu SELESAI." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Tips Flowchart Rapi" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="12dp"
                    android:text="1. Mulai dengan MULAI" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Setiap flowchart harus punya awal supaya Robot Algo tahu dari mana memulai." />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="14dp"
                    android:text="2. Akhiri dengan SELESAI" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Kalau tidak ada bagian selesai, Algo bisa terus mencari-cari akhir jalannya." />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="14dp"
                    android:text="3. Gunakan simbol yang sesuai" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Oval untuk MULAI dan SELESAI, persegi panjang untuk langkah, belah ketupat untuk pilihan, dan panah untuk arah." />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="14dp"
                    android:text="4. Buat panah jelas" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Panah harus menunjukkan langkah berikutnya. Jangan sampai panahnya terlalu banyak menyilang." />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="14dp"
                    android:text="5. Gunakan kata singkat" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Teks di dalam flowchart sebaiknya pendek dan jelas. Misalnya: Ambil gelas." />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="14dp"
                    android:text="6. Susun dari atas ke bawah" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Robot Algo tinggal mengikuti panah dari atas sampai bawah." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Contoh Flowchart Rapi" />

                <ImageView
                    style="@style/LessonIllustration"
                    android:contentDescription="Contoh flowchart rapi"
                    android:src="@drawable/materi8_contohflowchart" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Kesimpulan" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Flowchart yang rapi harus mudah dibaca. Kita perlu MULAI, SELESAI, simbol yang sesuai, panah yang jelas, langkah singkat, dan urutan yang benar." />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Flowchart yang rapi membuat Robot Algo tidak bingung!" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Mini Game" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="8dp"
                    android:text="Rapikan Flowchart Robot Algo!" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Flowchart mencuci tangan milik Algo berantakan. Ketuk bagian yang perlu diperbaiki supaya flowchart-nya rapi." />

                <LinearLayout
                    android:id="@+id/gameSlotContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <LinearLayout
                    android:id="@+id/gameChoiceContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnResetGame"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_auth_switch_panel"
                        android:gravity="center"
                        android:text="Ulangi"
                        android:textColor="@color/algoplay_blue_dark"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnCheckGame"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_green"
                        android:gravity="center"
                        android:text="Cek Temuan"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Quiz Singkat" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="10dp"
                    android:text="1. Flowchart yang rapi sebaiknya memiliki..." />

                <LinearLayout
                    android:id="@+id/quizOneContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="16dp"
                    android:text="2. Teks di dalam simbol flowchart sebaiknya..." />

                <LinearLayout
                    android:id="@+id/quizTwoContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_stat_green"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:lineSpacingExtra="2dp"
                    android:text="Hebat! Sekarang kamu tahu cara membuat flowchart yang rapi. Kalau flowchart rapi, Robot Algo bisa mengikuti langkahnya tanpa bingung!"
                    android:textColor="@color/algoplay_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_marginStart="8dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="Robot senang"
                    android:scaleType="fitCenter"
                    android:src="@drawable/sorakan_leaderboard" />

            </LinearLayout>

            <TextView
                android:id="@+id/btnFinishLesson"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_button_blue"
                android:gravity="center"
                android:text="Lanjut ke Materi 9"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/lessonTopBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="top"
        android:layout_marginStart="24dp"
        android:layout_marginTop="38dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_home_card"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.08"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/lessonTopAvatarWrap"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_profile_avatar"
                android:padding="7dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgLessonTopPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Foto profil"
                    android:src="@drawable/ic_user"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.AlgoPlay.Circle"
                    app:tint="@color/algoplay_blue_dark" />

            </FrameLayout>

            <TextView
                android:id="@+id/txtLessonTopName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Teman"
                android:textColor="@color/algoplay_text"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1.15"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtLessonTopDay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Minggu"
                android:textColor="@color/algoplay_blue_dark"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLessonTopDateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="7 Juni 2026 - 04:37"
                android:textColor="@color/algoplay_subtext"
                android:textSize="11sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/lessonRankBadge"
            android:layout_width="92dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_reward_chip"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/txtLessonRankLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="Tingkat 1"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLessonRankStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Beginner"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
