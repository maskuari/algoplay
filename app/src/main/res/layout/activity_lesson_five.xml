<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tab_materi"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ScrollView
        android:id="@+id/lessonScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="112dp"
        android:paddingBottom="30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="188dp"
                android:background="@drawable/bg_home_hero_clean"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:elevation="2dp"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="10dp"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingEnd="132dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="Materi 5"
                        android:textColor="@color/algoplay_green_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="1dp"
                        android:text="Mengenal Pseudocode dengan Mudah"
                        android:textColor="@color/algoplay_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="2dp"
                        android:text="Belajar menulis langkah seperti kode, tapi tetap mudah dibaca."
                        android:textColor="@color/algoplay_subtext"
                        android:textSize="13sp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="134dp"
                    android:layout_height="134dp"
                    android:layout_gravity="end|center_vertical"
                    android:adjustViewBounds="true"
                    android:contentDescription="Robot Algo belajar pseudocode"
                    android:scaleType="fitCenter"
                    android:src="@drawable/informasi_penjelasan" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Tujuan Materi" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Anak-anak mengenal bahwa pseudocode adalah cara menulis langkah seperti kode, tetapi masih memakai bahasa manusia yang mudah dimengerti." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Halo, teman-teman!" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Robot Algo datang lagi nih! Hari ini kita belajar hal baru yang namanya pseudocode. Namanya terdengar keren, tapi tenang, ini tidak sesulit namanya kok." />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Pseudocode dibaca seperti su-do-kod. Pseudocode adalah cara menulis langkah-langkah seperti kode komputer, tapi masih memakai bahasa yang mudah kita pahami." />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Jadi, pseudocode itu seperti jembatan antara bahasa manusia dan bahasa komputer." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Penjelasan Fun" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Coba bayangkan Robot Algo ingin membuat susu. Kalau ditulis biasa, langkahnya bisa seperti: siapkan gelas, masukkan susu, tuang air, aduk, lalu minum." />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="14dp"
                    android:text="Kalau ditulis pseudocode" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:typeface="monospace"
                    android:text="MULAI\nSiapkan gelas\nMasukkan susu\nTuang air\nAduk susu\nMinum susu\nSELESAI" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Lihat, masih mudah dibaca kan? Bedanya, pseudocode biasanya punya tanda awal MULAI dan tanda akhir SELESAI." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Langkah Biasa vs Pseudocode" />

                <ImageView
                    style="@style/LessonIllustration"
                    android:contentDescription="Perbandingan langkah biasa dan pseudocode"
                    android:src="@drawable/materi5_biasavspseudocode" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="12dp"
                    android:text="Langkah biasa" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Ambil buku.\nBuka halaman.\nBaca cerita.\nTutup buku." />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="14dp"
                    android:text="Pseudocode" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:typeface="monospace"
                    android:text="MULAI\nAmbil buku\nBuka halaman\nBaca cerita\nTutup buku\nSELESAI" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Pseudocode terlihat seperti kode, tapi tetap gampang dimengerti. Jadi anak-anak tidak perlu takut." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Contoh Sehari-hari" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="12dp"
                    android:text="Memakai Sepatu" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:typeface="monospace"
                    android:text="MULAI\nAmbil kaus kaki\nPakai kaus kaki\nAmbil sepatu\nPakai sepatu\nIkat tali sepatu\nSELESAI" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="14dp"
                    android:text="Menyalakan Lampu" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:typeface="monospace"
                    android:text="MULAI\nPergi ke saklar\nTekan saklar lampu\nLampu menyala\nSELESAI" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="14dp"
                    android:text="Mencuci Tangan" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:typeface="monospace"
                    android:text="MULAI\nBasahi tangan\nAmbil sabun\nGosok tangan\nBilas dengan air\nKeringkan tangan\nSELESAI" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Kesimpulan" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Pseudocode adalah cara menulis langkah-langkah seperti kode, tapi tetap memakai bahasa yang mudah dimengerti." />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Pseudocode biasanya punya bagian awal, langkah-langkah, dan bagian akhir. Ingat ya: MULAI, langkah-langkah, lalu SELESAI." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Mini Game" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="8dp"
                    android:text="Pilih Pseudocode yang Benar!" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Robot Algo ingin mencuci tangan. Bantu Algo memilih pseudocode yang urut dan rapi supaya tangannya bersih." />

                <LinearLayout
                    android:id="@+id/gameSlotContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <LinearLayout
                    android:id="@+id/gameChoiceContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnResetGame"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_auth_switch_panel"
                        android:gravity="center"
                        android:text="Ulangi"
                        android:textColor="@color/algoplay_blue_dark"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnCheckGame"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_green"
                        android:gravity="center"
                        android:text="Cek Pilihan"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Quiz Singkat" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="10dp"
                    android:text="1. Pseudocode adalah..." />

                <LinearLayout
                    android:id="@+id/quizOneContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="16dp"
                    android:text="2. Biasanya pseudocode diawali dengan kata..." />

                <LinearLayout
                    android:id="@+id/quizTwoContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_stat_green"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:lineSpacingExtra="2dp"
                    android:text="Keren! Sekarang kamu sudah mengenal pseudocode. Pseudocode membantu kita menulis langkah dengan rapi seperti perintah untuk Robot Algo."
                    android:textColor="@color/algoplay_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_marginStart="8dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="Robot senang"
                    android:scaleType="fitCenter"
                    android:src="@drawable/sorakan_leaderboard" />

            </LinearLayout>

            <TextView
                android:id="@+id/btnFinishLesson"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_button_blue"
                android:gravity="center"
                android:text="Lanjut ke Materi 6"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/lessonTopBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="top"
        android:layout_marginStart="24dp"
        android:layout_marginTop="38dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_home_card"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.08"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/lessonTopAvatarWrap"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_profile_avatar"
                android:padding="7dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgLessonTopPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Foto profil"
                    android:src="@drawable/ic_user"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.AlgoPlay.Circle"
                    app:tint="@color/algoplay_blue_dark" />

            </FrameLayout>

            <TextView
                android:id="@+id/txtLessonTopName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Teman"
                android:textColor="@color/algoplay_text"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1.15"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtLessonTopDay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Minggu"
                android:textColor="@color/algoplay_blue_dark"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLessonTopDateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="7 Juni 2026 - 04:37"
                android:textColor="@color/algoplay_subtext"
                android:textSize="11sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/lessonRankBadge"
            android:layout_width="92dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_reward_chip"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/txtLessonRankLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="Tingkat 1"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLessonRankStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Beginner"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
