<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tab_materi"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ScrollView
        android:id="@+id/lessonScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="112dp"
        android:paddingBottom="30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="188dp"
                android:background="@drawable/bg_home_hero_clean"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:elevation="2dp"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="10dp"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingEnd="132dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="Materi 9"
                        android:textColor="@color/algoplay_green_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="1dp"
                        android:text="Belajar Pilihan: Jika Iya atau Tidak"
                        android:textColor="@color/algoplay_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="2dp"
                        android:text="Belajar memilih jalan yang cocok dari jawaban IYA atau TIDAK."
                        android:textColor="@color/algoplay_subtext"
                        android:textSize="13sp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="134dp"
                    android:layout_height="134dp"
                    android:layout_gravity="end|center_vertical"
                    android:adjustViewBounds="true"
                    android:contentDescription="Robot Algo memilih jalan"
                    android:scaleType="fitCenter"
                    android:src="@drawable/hai_materi" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Tujuan Materi" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Anak-anak memahami bahwa dalam algoritma ada bagian pilihan. Jawaban IYA atau TIDAK akan menentukan langkah berikutnya." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Halo, teman-teman!" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Robot Algo datang lagi nih! Hari ini kita belajar tentang pilihan. Kadang-kadang, saat melakukan sesuatu, kita harus memilih." />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Contohnya: apakah hari ini hujan? Kalau jawabannya IYA, kita membawa payung. Kalau jawabannya TIDAK, kita tidak perlu membawa payung." />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Dalam algoritma, kita bisa membuat pertanyaan. Dari pertanyaan itu, ada dua jalan: IYA atau TIDAK." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Penjelasan Fun" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Bayangkan Robot Algo mau pergi bermain ke taman. Sebelum pergi, Algo melihat ke luar rumah dan bertanya: apakah hujan?" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Kalau IYA, Robot Algo harus membawa payung. Kalau TIDAK, Robot Algo bisa langsung pergi bermain." />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Pilihan membantu Robot Algo menentukan langkah berikutnya. Tanpa pilihan, Algo bisa salah jalan dan basah kuyup." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Contoh Sehari-hari" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="12dp"
                    android:text="Jika Hujan" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Pertanyaan: Apakah hujan?\nJika IYA: Bawa payung.\nJika TIDAK: Tidak perlu membawa payung." />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="14dp"
                    android:text="Jika Lapar" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Pertanyaan: Apakah kamu lapar?\nJika IYA: Makan dulu.\nJika TIDAK: Lanjut bermain." />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="14dp"
                    android:text="Jika Lampu Mati" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Pertanyaan: Apakah lampu mati?\nJika IYA: Tekan saklar lampu.\nJika TIDAK: Lampu tetap menyala." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Pilihan dalam Flowchart" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Dalam flowchart, pilihan biasanya memakai simbol belah ketupat. Simbol ini berisi pertanyaan." />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="14dp"
                    android:text="Contoh: Apakah hujan?" />

                <ImageView
                    style="@style/LessonIllustration"
                    android:contentDescription="Pilihan dalam flowchart apakah hujan"
                    android:src="@drawable/materi9_pilihanflowchart" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Jadi, pilihan membuat flowchart punya dua jalan berbeda." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Contoh Algoritma Pilihan" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:typeface="monospace"
                    android:text="MULAI\nLihat ke luar rumah\nApakah hujan?\nJika IYA, bawa payung\nJika TIDAK, pergi tanpa payung\nSELESAI" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Robot Algo tinggal menjawab pertanyaannya dulu. Setelah itu, dia memilih langkah yang sesuai." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Kesimpulan" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="8dp"
                    android:text="Pilihan dalam algoritma digunakan saat ada pertanyaan. Biasanya jawabannya IYA atau TIDAK, dan jawaban itu menentukan langkah berikutnya." />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="10dp"
                    android:text="Kalau ada pertanyaan, pikirkan jawabannya dulu. Setelah itu, pilih langkah yang cocok." />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Mini Game" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="8dp"
                    android:text="Bantu Robot Algo Memilih Jalan!" />

                <TextView
                    style="@style/LessonBodyText"
                    android:layout_marginTop="6dp"
                    android:text="Lihat cuacanya, jawab IYA atau TIDAK, lalu pilih langkah yang cocok untuk Robot Algo." />

                <LinearLayout
                    android:id="@+id/gameSlotContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <LinearLayout
                    android:id="@+id/gameChoiceContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnResetGame"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_auth_switch_panel"
                        android:gravity="center"
                        android:text="Ulangi"
                        android:textColor="@color/algoplay_blue_dark"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnCheckGame"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_green"
                        android:gravity="center"
                        android:text="Cek Pilihan"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/LessonSectionTitle"
                    android:text="Quiz Singkat" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="10dp"
                    android:text="1. Jika hari hujan, apa yang sebaiknya kita lakukan sebelum keluar rumah?" />

                <LinearLayout
                    android:id="@+id/quizOneContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

                <TextView
                    style="@style/LessonSubTitle"
                    android:layout_marginTop="16dp"
                    android:text="2. Dalam algoritma, pilihan biasanya memiliki jawaban..." />

                <LinearLayout
                    android:id="@+id/quizTwoContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_stat_green"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:lineSpacingExtra="2dp"
                    android:text="Hebat! Sekarang kamu tahu bahwa algoritma bisa punya pilihan. Kalau jawabannya berbeda, langkah berikutnya juga bisa berbeda!"
                    android:textColor="@color/algoplay_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_marginStart="8dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="Robot senang"
                    android:scaleType="fitCenter"
                    android:src="@drawable/sorakan_leaderboard" />

            </LinearLayout>

            <TextView
                android:id="@+id/btnFinishLesson"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_button_blue"
                android:gravity="center"
                android:text="Lanjut ke Materi 10"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/lessonTopBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="top"
        android:layout_marginStart="24dp"
        android:layout_marginTop="38dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_home_card"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.08"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/lessonTopAvatarWrap"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_profile_avatar"
                android:padding="7dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgLessonTopPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Foto profil"
                    android:src="@drawable/ic_user"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.AlgoPlay.Circle"
                    app:tint="@color/algoplay_blue_dark" />

            </FrameLayout>

            <TextView
                android:id="@+id/txtLessonTopName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Teman"
                android:textColor="@color/algoplay_text"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1.15"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtLessonTopDay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Minggu"
                android:textColor="@color/algoplay_blue_dark"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLessonTopDateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="7 Juni 2026 - 04:37"
                android:textColor="@color/algoplay_subtext"
                android:textSize="11sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/lessonRankBadge"
            android:layout_width="92dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_reward_chip"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/txtLessonRankLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="Tingkat 1"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLessonRankStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Beginner"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
