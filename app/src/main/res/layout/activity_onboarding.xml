<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/onboardingRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_page"
    android:clipChildren="false"
    android:clipToPadding="false">

    <View
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="72dp"
        android:layout_marginEnd="-50dp"
        android:background="@drawable/bg_bubble_mint" />

    <View
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-28dp"
        android:layout_marginBottom="136dp"
        android:background="@drawable/bg_bubble_yellow" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="42dp"
        android:paddingEnd="28dp"
        android:paddingBottom="34dp">

        <ImageView
            android:layout_width="156dp"
            android:layout_height="62dp"
            android:adjustViewBounds="true"
            android:contentDescription="Logo AlgoPlay"
            android:scaleType="fitCenter"
            android:src="@drawable/logo2" />

        <ImageView
            android:id="@+id/imgAlbi"
            android:layout_width="330dp"
            android:layout_height="306dp"
            android:layout_marginTop="28dp"
            android:adjustViewBounds="true"
            android:contentDescription="Maskot AlgoPlay membuka petualangan"
            android:scaleType="fitCenter"
            android:src="@drawable/welcome" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="Belajar Algoritma Jadi Seru"
            android:textColor="@color/algoplay_text"
            android:textSize="29sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Masuk ke dunia flowchart, puzzle, kuis, dan reward bersama Albi."
            android:textColor="@color/algoplay_subtext"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_detail_chip"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Materi"
                android:textColor="@color/algoplay_blue_dark"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_detail_chip"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Game"
                android:textColor="@color/algoplay_blue_dark"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_detail_chip"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Reward"
                android:textColor="@color/algoplay_blue_dark"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartAdventure"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:backgroundTint="@color/algoplay_blue"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Mulai Belajar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="20dp" />

    </LinearLayout>

</FrameLayout>
